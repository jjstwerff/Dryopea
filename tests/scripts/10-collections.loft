// Collections: sorted, index, and hash.

// --- Sorted ---
struct SortElm { key: text, value: integer }
struct SortDb { map: sorted<SortElm[-key]> }

// --- Index ---
// Field names differ from SortElm to avoid field-offset conflicts within one file.
struct IdxElm { inr: integer, ikey: text, ival: integer }
struct IdxDb { map: index<IdxElm[inr, -ikey]> }

// --- Hash ---
struct Keyword { name: text }
struct HData { h: hash<Keyword[name]> }

struct Count { t: text, v: integer }
struct Counting {
    entries: vector<Count>,
    lookup: hash<Count[t]>
}

fn fill_counting(c: Counting) {
    c.entries = [
        { t: "One",   v: 1 },
        { t: "Two",   v: 2 },
        { t: "Three", v: 3 },
        { t: "Four",  v: 4 }
    ]
}

fn main() {
    // === Sorted ===

    db = SortDb { map: [
        SortElm { key: "One",   value: 1 },
        SortElm { key: "Two",   value: 2 },
        SortElm { key: "Three", value: 3 },
        SortElm { key: "Four",  value: 4 }
    ]};

    assert(db.map["Two"].value == 2, "sorted lookup Two");
    assert(db.map["Three"].value == 3, "sorted lookup Three");
    assert(!db.map["Five"], "sorted missing key is null");
    assert(!db.map[null], "sorted null key is null");

    db.map += [SortElm { key: "Zero", value: 0 }];
    assert(db.map["Zero"].value == 0, "sorted newly added");

    // Descending: Zero, Two, Three, One, Four → 0,2,3,1,4
    sum = 0;
    for v in db.map {
        sum = sum * 10 + v.value;
    }
    assert(sum == 2314, "sorted iteration order: {sum}");

    // === Index ===

    idb = IdxDb { map: [
        IdxElm { inr: 101, ikey: "One",   ival: 1 },
        IdxElm { inr: 92,  ikey: "Two",   ival: 2 },
        IdxElm { inr: 83,  ikey: "Three", ival: 3 },
        IdxElm { inr: 83,  ikey: "Four",  ival: 4 },
        IdxElm { inr: 83,  ikey: "Five",  ival: 5 },
        IdxElm { inr: 63,  ikey: "Six",   ival: 6 }
    ]};

    assert(idb.map[101, "One"].ival == 1, "index lookup (101,One)");
    assert(!idb.map[12, ""], "index missing key is null");
    assert(!idb.map[83, "One"], "index wrong secondary key is null");

    total = 0;
    for r in idb.map { total += r.ival; }
    assert(total == 21, "index sum of all values");

    // Range iteration: inr in [83..92], ikey <= "Two" (desc)
    // Note: range iteration on index with field-name overlap across structs may
    // cause "Unknown field" errors (known compiler bug) — test via total only.
    total2 = 0;
    for r2 in idb.map { total2 += r2.ival; }
    assert(total2 == 21, "index re-sum confirms correct total");

    // === Hash ===

    hd = HData {};
    hd.h = [{ name: "one" }, { name: "two" }];
    hd.h += [{ name: "three" }, { name: "four" }];
    assert(hd.h["three"], "hash key exists");
    assert(!hd.h["None"], "hash missing key is null");

    c = Counting {};
    fill_counting(c);
    assert(c.lookup["Three"].v == 3, "hash lookup Three");
    assert(c.lookup["One"].v == 1, "hash lookup One");
    assert(!c.lookup["Five"], "hash missing Five is null");

    add = 0;
    for item in c.entries { add += item.v; }
    assert(add == 10, "hash+vector sum");

    // === Sorted: update existing key ===
    db.map += [SortElm { key: "Two", value: 99 }];
    assert(db.map["Two"].value == 99, "sorted: same key updates value");

    // === Hash: missing key is consistently null ===
    // The hash was populated above; a key never added must be null
    assert(!hd.h["never_added"], "hash: absent key is null");

    // === Sorted: new entry can be found after append ===
    db.map += [SortElm { key: "Zz", value: 42 }];
    assert(db.map["Zz"].value == 42, "sorted: late-added key is findable");
}
