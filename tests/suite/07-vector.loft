// @NAME: Vector
// @TITLE: Vector creation and use
// Dynamic arrays: literals, slices, removal, reverse iteration, and for-loops embedded in format strings.
fn main() {
    // A vector literal is written with square brackets.
    // '#first' is true for the first element; '#index' gives the position.
    x = [1, 3, 6, 9];
    b = "";
    for v in x {
        if !v#first {
            b += " ";
        }
        b += "{v#index}:{v}"
    }
    assert(b == "0:1 1:3 2:6 3:9", "result {b}");

    // Append another vector with '+='. Then remove elements while iterating
    // using 'v#remove' inside a filtered loop.
    x += [12, 14, 15];
    for v in x if v % 3 != 0 {
        v#remove;
    }
    assert("{x}" == "[3,6,9,12,15]", "result {x}");

    // A range index extracts a sub-vector; the upper bound is exclusive.
    // Omitting the upper bound goes to the end of the vector.
    pows = [1, 2, 4, 8, 16];
    assert("{pows[1..3]}" == "[2,4]", "Sub-vector");
    assert("{pows[3..]}" == "[8,16]", "Open-ended sub-vector");

    // Accessing an index outside the vector's bounds returns null.
    assert(!pows[10], "Out-of-bounds access returns null");

    // A for loop can be written directly inside a format string.
    // An optional format specifier after ':' applies to every element.
    assert("{for n in 1..7 {n*2}:02}" == "[02,04,06,08,10,12]", "Formatted vector loop");

    // Reverse iteration uses rev() on the range.
    c = 0;
    for e in pows[rev(0..=3)] {
        c = c * 10 + e;
    }
    assert(c == 8421, "Reverse sub-vector iteration");

    // Vectors are passed by reference to functions; changes are visible to the caller.
    // A vector of structs can be created with a repeated element using '; count'.
    // (See 08-struct.loft for struct syntax.)
}
