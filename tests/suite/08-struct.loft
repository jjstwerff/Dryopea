// @NAME: Structs
// @TITLE: Record definitions and use
// Record types: field constraints, computed fields using $, methods, JSON and pretty-print formatting.
struct Area {
    height: u16,
    terrain: u8,
    water: u8,
    direction: u8
}

// ## Field Constraints
// 'limit(min, max)' constrains an integer field to a range.
// 'not null' makes zero a valid stored value instead of the null sentinel.
// Fields omitted in a constructor default to zero (or null for nullable fields).
struct Point {
    r: integer limit(0, 255) not null,
    g: integer limit(0, 255) not null,
    b: integer limit(0, 255) not null
}

// ## Methods
// A method is a function whose first parameter is named 'self' with the struct type.
// It is called with dot notation: value.method().
fn value(self: Point) -> integer {
    self.r * 0x10000 + self.g * 0x100 + self.b
}

// ## Computed Fields
// 'default(expr)' and 'virtual(expr)' compute a field value from other fields.
// '$' refers to the struct being initialised.
struct Object {
    name_length: integer = len($.name),
    name: text
}

fn main() {
    // A vector of structs can be initialised with a repeated element using '; count'.
    map = [Area {height:0, terrain:1, water:1, direction:1}; 16 ];
    assert("{map[3]}" == "{{height:0,terrain:1,water:1,direction:1}}", "record {map[3]}");

    // Fields not mentioned in the constructor receive their zero/null default.
    p = Point { r:128, b:128 };
    assert(p.g == 0, "Omitted field defaults to zero");
    assert("{p}" == "{{r:128,g:0,b:128}}", "Struct compact formatting");

    // The ':# ' format specifier produces pretty-printed output with newlines.
    // The ':j' specifier produces JSON.
    o = Object { name: "hello" };
    assert(o.name_length == 5, "Calculated field");
    assert("{o:j}" == "{{\"name_length\":5,\"name\":\"hello\"}}", "JSON format");

    // Methods are called with dot notation; the result can be formatted inline.
    purple = Point { r:128, b:128 };
    assert("{purple.value():x}" == "800080", "Method result in format");

    // Limitation: do not call a method directly on a constructor expression.
    // The parser rejects 'MyStruct { ... }.method()' — assign to a variable first:
    //   tmp = Point { r: 1, g: 2, b: 3 };
    //   result = tmp.value();
    //
    // Limitation: methods that return a new struct record (-> MyStruct) currently
    // crash at runtime. Methods that return scalars (integer, float, text) or
    // modify 'self' in place work correctly.
}
// defaults on fields & null defaults
