// @NAME: Integers
// @TITLE: Base numeric operations

// Numbers are at the heart of almost every program. This page covers the
// integer types Loft provides, the arithmetic and bitwise operations you can
// perform on them, how to convert between numbers and text, and what Loft
// does when something goes wrong — such as dividing by zero.
//
// The default number type is 'integer': a 32-bit signed whole number, the
// same as i32 in Rust. It can hold values from roughly -2 billion to +2 billion.
// For larger values Loft also has 'long' (64-bit), shown at the end of this page.

fn main() {
    // ## Converting between numbers and text
    // Wrapping a value in curly braces inside a double-quoted string formats
    // it as text and inserts it at that position. Going the other way, 'as integer'
    // parses a text value into a number. These conversions are used constantly
    // when reading input or producing output.
    v = 4;
    assert("{v}" == "4", "Convert numbers to text");
    assert("123" as integer == 123, "Convert text to number");

    // ## Arithmetic and operator precedence
    // Loft follows standard mathematical precedence: multiplication and division
    // happen before addition and subtraction. Bitwise operators like '<<' (left
    // shift), '&' (bitwise AND), and '^' (bitwise XOR) also have defined
    // precedence — when mixing them with arithmetic, parentheses make your
    // intent clear and avoid surprises.
    // Note: '^' is XOR, not exponentiation. For powers, use pow(base, exp).
    assert(1 + 2 * 4 == 9, "Integer calculus");
    assert(1 + 2 << 2 == 12, "Binary shift");
    assert(0x0a8 & 15 == 8, "Binary and");
    assert(42 ^ 0b111111 == 21, "Binary xor");
    assert(105 % 100 == 5, "Modulus");
    assert(pow(2.0, 3.0) == 8.0, "Power");

    // 'abs()' returns the absolute value of a number — always non-negative.
    // It is a plain function call, not a method, so write abs(x) not x.abs().
    assert(1 + abs(-2) == 3, "Absolute integer");

    // ## Division by zero produces null
    // Unlike many languages, Loft does not crash or throw an exception when you
    // divide by zero. Instead the result is null — a special "no value" state.
    // In a condition, null behaves like false, so you can test for it with '!'.
    // This makes it easy to handle bad input gracefully without try/catch.
    a = 2 * 2;
    a -= 4;
    assert(!(12 / a), "Null on division by zero");

    assert("a{12}b" == "a12b", "Formatting problem");

    // ## Hex formatting with '#x'
    // You can include a full expression inside a format placeholder, not just
    // a variable name. Adding '#x' after the ':' formats the result as a
    // hexadecimal number with a leading '0x' prefix.
    assert("a{1 + 2 * 3:#x}b" == "a0x7b", "Hex formatting");

    // Hexadecimal literals in source code can use either lowercase (a–f) or
    // uppercase (A–F) digits — both are valid and mean the same thing.
    assert(0xff == 255, "Lowercase hex literal");
    assert(0x2a == 42, "Lowercase hex literal 2");
    assert(0xFF == 255, "Uppercase hex literal");
    assert(0x2A == 42, "Uppercase hex literal 2");

    // ## Number format specifiers
    // A format specifier after ':' controls how a number is displayed:
    // '#x' = hexadecimal with '0x' prefix, 'o' = octal, 'b' = binary,
    // '+' = always show a sign (+ or -), 'N' = minimum width (space-padded),
    // '0N' = minimum width with zero-padding.
    // These can be combined: '+4' means sign + at least 4 characters wide.
    assert("ab{1+2+32:#x}c{12:o}d{391}e{12:+4}f{1:03}g{42:b}h" == "ab0x23c14d391e +12f001g101010h", "Integer formats");

    // ## The 'long' type for large numbers
    // When values might exceed the 32-bit integer range, use 'long' (64-bit).
    // Write a long literal by appending 'l' to the number: '1l', '100l'.
    // Long values support the same arithmetic and format specifiers as integer.
    // Use 'as integer' to convert a long back to a regular integer.
    assert("a{1l+1:+4}b{12l as integer}c {2l * (4l % 6l) >= 8} d" == "a  +2b12c true d", "Long formatting");
}
