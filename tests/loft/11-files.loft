// File I/O: text files, binary (u8/u16/i32/long/single/float/text/vector), seek, size, move/delete.

// Clean up any leftover files from a previous interrupted run.
fn cleanup() {
    delete("test_loft_a.bin");
    delete("test_loft_b.bin");
    delete("test_loft_t.txt");
    delete("test_loft_src.txt");
    delete("test_loft_dst.txt");
}

fn main() {
    cleanup();

    // --- file() format detection ---
    assert(file("example").format == Directory, "directory format");
    assert(file("example/show.loft").format == TextFile, "text file format");
    assert(file("nonexistent_xyz.txt").format == NotExists, "nonexistent format");

    // --- Path safety: traversal outside project is rejected ---
    assert(file("../Cargo.toml").format == NotExists, ".. at start rejected");
    assert(file("example/../../etc").format == NotExists, "net upward rejected");
    assert(file("example/../example/show.loft").format == TextFile, "net-zero traversal ok");

    // --- exists() ---
    assert(exists("example"), "exists: directory");
    assert(exists("example/show.loft"), "exists: file");
    assert(!exists("nonexistent_xyz.txt"), "exists: missing");
    assert(!exists("../Cargo.toml"), "exists: outside project");

    // --- delete() returns false for non-existent ---
    assert(!delete("nonexistent_xyz.txt"), "delete non-existent returns false");
    assert(!delete("../Cargo.toml"), "delete outside project returns false");

    // --- move() edge cases ---
    assert(!move("nonexistent_src_xyz.txt", "dst_xyz.txt"), "move: missing source");
    assert(!move("example/show.loft", "example/map.png"), "move: dst already exists");
    assert(!move("example/show.loft", "../outside.txt"), "move: dst outside project");
    assert(!move("../Cargo.toml", "stolen.toml"), "move: src outside project");

    // === Text file write and read ===

    { f = file("test_loft_t.txt");
      f += "Hello World";
      assert(f#size == 11l, "text write size 11");
      assert(f#index == 0l, "text write #index is start of write");
      assert(f#next == 11l, "text write #next at end");
    }
    assert(exists("test_loft_t.txt"), "text file created");

    { g = file("test_loft_t.txt");
      s = g#read(5) as text;
      assert(s == "Hello", "text read first 5");
      assert(g#index == 0l, "text read #index after first");
      assert(g#next == 5l, "text read #next after first");
      s2 = g#read(6) as text;
      assert(s2 == " World", "text read next 6");
      assert(g#index == 5l, "text read #index after second");
      assert(g#next == 11l, "text read #next after second");
      // Read past EOF returns partial
      g#next = 8l;
      tail = g#read(100) as text;
      assert(tail == "rld", "text read past eof returns partial");
      // Seek back to start
      g#next = 0l;
      again = g#read(5) as text;
      assert(again == "Hello", "text seek and reread");
    }
    assert(delete("test_loft_t.txt"), "delete text file");

    // === Binary: u8 ===

    { f = file("test_loft_a.bin");
      f#format = BigEndian;
      f += 0 as u8;
      f += 255 as u8;
      assert(f#size == 2l, "u8 write size");
    }
    { g = file("test_loft_a.bin");
      g#format = BigEndian;
      assert(g#read(1) as u8 == 0, "u8 read 0");
      assert(g#read(1) as u8 == 255, "u8 read 255");
    }
    assert(delete("test_loft_a.bin"), "delete after u8 test");

    // === Binary: u16 ===

    { f = file("test_loft_a.bin");
      f#format = BigEndian;
      f += 0x0203 as u16;
    }
    { g = file("test_loft_a.bin");
      g#format = BigEndian;
      assert(g#read(2) as u16 == 0x0203, "u16 read BigEndian");
    }
    // Little-endian: bytes are [03,02] so LE read gives 0x0203 still
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      assert(g#read(2) as u16 == 0x0302, "u16 bytes swapped in LE");
    }
    assert(delete("test_loft_a.bin"), "delete after u16 test");

    // === Binary: i32 (LittleEndian) ===

    { f = file("test_loft_a.bin");
      f#format = LittleEndian;
      f += 0x11223344;
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      assert(g#read(4) as i32 == 0x11223344, "i32 LE roundtrip");
    }
    // Same bytes read as BigEndian give byte-swapped value
    { g = file("test_loft_a.bin");
      g#format = BigEndian;
      assert(g#read(4) as i32 == 0x44332211, "i32 LE bytes read as BE");
    }
    assert(delete("test_loft_a.bin"), "delete after i32 test");

    // === Binary: i32 (BigEndian) ===

    { f = file("test_loft_a.bin");
      f#format = BigEndian;
      f += 0x11223344;
    }
    { g = file("test_loft_a.bin");
      g#format = BigEndian;
      assert(g#read(4) as i32 == 0x11223344, "i32 BE roundtrip");
    }
    assert(delete("test_loft_a.bin"), "delete after i32 BE test");

    // === Binary: long (i64) ===

    { f = file("test_loft_a.bin");
      f#format = LittleEndian;
      f += 0x0102030405060708l;
      assert(f#size == 8l, "long write size");
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      assert(g#read(8) as long == 0x0102030405060708l, "long LE roundtrip");
    }
    assert(delete("test_loft_a.bin"), "delete after long test");

    // === Binary: single (f32) ===

    { f = file("test_loft_a.bin");
      f#format = LittleEndian;
      f += 1.5f;
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      assert(g#read(4) as single == 1.5f, "single LE roundtrip");
    }
    assert(delete("test_loft_a.bin"), "delete after single test");

    // === Binary: float (f64) ===

    { f = file("test_loft_a.bin");
      f#format = LittleEndian;
      f += 3.14;
      assert(f#size == 8l, "float write size");
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      assert(g#read(8) as float == 3.14, "float LE roundtrip");
    }
    assert(delete("test_loft_a.bin"), "delete after float test");

    // === Binary: text (raw UTF-8, no length prefix) ===

    { f = file("test_loft_a.bin");
      f#format = LittleEndian;
      f += "Hello";
      assert(f#size == 5l, "text binary write size");
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      assert(g#read(5) as text == "Hello", "text binary read");
      g#next = 0l;
      assert(g#read(100) as text == "Hello", "text read past eof full");
    }
    assert(delete("test_loft_a.bin"), "delete after text binary test");

    // === Binary: vector of singles ===
    // Note: f += vector<single> is not yet implemented (writes 0 bytes). Test skipped.

    // === Mixed write: sequential types ===

    { f = file("test_loft_a.bin");
      f#format = BigEndian;
      f += 0 as u8;
      f += 1 as u8;
      f += 0x0203 as u16;
      f += 0x04050607;
      f += 0x08090a0b0c0d0e0fl;
      assert(f#size == 16l, "mixed write total 16 bytes");
      f += "Hello world!";
      assert(f#size == 28l, "mixed write with text 28 bytes");
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      // First 4 bytes as LE: [0x00,0x01,0x02,0x03] → 0x03020100
      assert(g#read(4) as i32 == 0x03020100, "mixed LE read first 4");
      assert(g#index == 0l, "#index at start");
      assert(g#next == 4l, "#next after first read");
      // Seek to text part
      g#next = 16l;
      assert(g#read(5) as text == "Hello", "mixed seek+read text");
      assert(g#index == 16l, "#index after seek");
      assert(g#next == 21l, "#next after text read");
      rest = g#read(100) as text;
      assert(rest == " world!", "mixed read to eof");
      assert(g#next == g#size, "#next at end == #size");
    }
    assert(delete("test_loft_a.bin"), "delete after mixed test");

    // === #size set (truncate / extend) ===
    // Note: f#size = n (set_file_size) is not yet implemented. Test skipped.

    // === seek then overwrite ===

    { f = file("test_loft_a.bin");
      f#format = LittleEndian;
      f += 0x11223344;
      f += 0x55667788;
      // Seek back to start and overwrite.
      // Use a value that fits in i32 (0xaabbccdd overflows i32).
      f#next = 0l;
      f += 0x11111111;
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      assert(g#read(4) as i32 == 0x11111111, "seek+overwrite first int");
      assert(g#read(4) as i32 == 0x55667788, "second int unchanged");
    }
    assert(delete("test_loft_a.bin"), "delete after seek overwrite test");

    // === Incomplete read (fewer bytes than type requires) → null, #next unchanged ===

    { f = file("test_loft_a.bin");
      f#format = LittleEndian;
      f += 42;
    }
    { g = file("test_loft_a.bin");
      g#format = LittleEndian;
      g#read(4) as i32;
      // Open file first with one read, then try to read 8 bytes as long (only 0 remain)
      g#next = 0l;
      g#read(8) as long;
      assert(g#next == 0l, "incomplete typed read: #next unchanged");
    }
    assert(delete("test_loft_a.bin"), "delete after incomplete read test");

    // === move() write-and-move cycle ===

    { f = file("test_loft_src.txt");
      f += "data";
    }
    assert(move("test_loft_src.txt", "test_loft_dst.txt"), "move succeeds");
    assert(!exists("test_loft_src.txt"), "source gone after move");
    assert(exists("test_loft_dst.txt"), "destination exists after move");
    assert(delete("test_loft_dst.txt"), "delete destination");

    // === lines() reads text file into vector ===

    c = file("example/config/terrain.txt").lines();
    assert(c[1] == "    terrain = [", "lines()[1] content");
}
