// Control flow: if/else, for loops, ranges, break, nested loops, loop metadata.

fn main() {
    // --- If / else if / else ---
    a = 12;
    if a > 10 and a & 7 == 4 {
        a += 1;
    } else {
        a -= 1;
    }
    assert(a == 13, "if-else: a should be 13");

    r = if a == 13 { "correct" } else if a == 12 { "almost" } else { "wrong" };
    assert(r == "correct", "if-else-if expression");

    // --- For range (exclusive) ---
    t = 0;
    for i in 1..6 {
        t += i;
    }
    assert(t == 15, "for 1..6 sum");

    // --- For range (inclusive) ---
    t = 0;
    for i in 1..=5 {
        t += i;
    }
    assert(t == 15, "for 1..=5 sum");

    // --- Reverse range ---
    t = 0;
    for i in rev(1..=5) {
        t = t * 10 + i;
    }
    assert(t == 54321, "rev range");

    // --- Break (inner loop) ---
    b = "";
    for x in 1..5 {
        for y in 1..5 {
            if y > x {
                break;
            }
            if len(b) > 0 { b += " "; }
            b += "{x}:{y}";
        }
    }
    assert(b == "1:1 2:1 2:2 3:1 3:2 3:3 4:1 4:2 4:3 4:4", "nested break inner");

    // --- Named break (outer loop) ---
    b = "";
    for x in 1..5 {
        for y in 1..5 {
            if x * y >= 16 {
                x#break;
            }
            if len(b) > 0 { b += "; "; }
            b += "{x}:{y}";
        }
    }
    assert(b == "1:1; 1:2; 1:3; 1:4; 2:1; 2:2; 2:3; 2:4; 3:1; 3:2; 3:3; 3:4; 4:1; 4:2; 4:3", "named break outer");

    // --- Loop filter (if guard) ---
    b = "";
    for x in 1..=9 if x % 3 != 1 {
        if !x#first { b += ", "; }
        b += "{x#count}:{x}";
    }
    assert(b == "0:2, 1:3, 2:5, 3:6, 4:8, 5:9", "for with filter");

    // --- #first and #index in range loop ---
    first_seen = false;
    idx_sum = 0;
    for v in [10, 20, 30] {
        if v#first { first_seen = true; }
        idx_sum += v#index;
    }
    assert(first_seen, "#first in vector loop");
    assert(idx_sum == 3, "#index sum 0+1+2");

    // --- Block as expression ---
    val = { x = 2; x * 3 };
    assert(val == 6, "block expression");
}
